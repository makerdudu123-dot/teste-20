rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'makerdudu123@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User validation
    function isValidUser(data) {
      return data.uid is string && 
             data.uid.size() <= 128 &&
             data.username is string && 
             data.username.size() >= 2 && 
             data.username.size() <= 50 &&
             data.email is string &&
             data.email.size() <= 100 &&
             data.gold is number && 
             data.gold >= 0 &&
             data.isRegistered is bool;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().uid == userId &&
                      incoming().gold == 1000;
      
      allow update: if (isOwner(userId) || isAdmin()) && 
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().email == existing().email &&
                      (
                        (incoming().diff(existing()).affectedKeys().hasOnly(['username', 'isRegistered', 'isVip', 'wins', 'losses', 'totalMatches'])) ||
                        (incoming().diff(existing()).affectedKeys().hasOnly(['gold']))
                      );
    }

    match /transactions/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /matches/{id} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.players || isAdmin());
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.players;
      allow update, delete: if isAdmin();
    }

    match /stats/{id} {
      allow read: if true;
      allow write: if isAdmin(); 
    }

    match /admins/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /rooms/{roomId} {
      function isValidRoom(data) {
        return data.id is string && 
               data.gameId is string && 
               data.creatorId is string &&
               data.status in ['waiting', 'playing'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRoom(incoming()) && incoming().creatorId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Creator can cancel/close OR update game data OR start match
        (existing().creatorId == request.auth.uid) ||
        // Guest can join
        (existing().status == 'waiting' && (incoming().status == 'ready' || incoming().status == 'playing') && incoming().guestId == request.auth.uid) ||
        // Guest can update game data when playing
        (existing().status == 'playing' && existing().guestId == request.auth.uid)
      );
      allow delete: if isSignedIn() && existing().creatorId == request.auth.uid;
    }
  }
}
